## Examples by Tech Stack

### Tailwind CSS

```tsx
// Primary button with icon
<Button className="bg-primary text-white hover:bg-primary/90">
  <Save className="w-4 h-4 mr-2" />
  Save Changes
</Button>

// Outline button for cancel
<Button
  variant="outline"
  className="border-border-strong text-text-secondary hover:bg-bg-subtle"
>
  Cancel
</Button>

// Ghost button for icons
<Button
  variant="ghost"
  size="icon"
  className="text-text-secondary hover:bg-bg-subtle"
>
  <Settings className="w-5 h-5" />
</Button>
```

### Bootstrap

```tsx
// Primary button
<button className="btn btn-primary">
  Save Changes
</button>

// Outline button
<button className="btn btn-outline-secondary">
  Cancel
</button>

// Icon button
<button className="btn btn-link">
  <Icon />
</button>
```

### Material UI

```tsx
// Primary button
<Button variant="contained" color="primary">
  Save Changes
</Button>

// Outline button
<Button variant="outlined" color="secondary">
  Cancel
</Button>

// Icon button
<IconButton>
  <SettingsIcon />
</IconButton>
```

### React Native

```tsx
// Primary button
<TouchableOpacity 
  style={{ 
    backgroundColor: colors.primary, 
    padding: 16, 
    borderRadius: 8,
    alignItems: 'center'
  }}
>
  <Text style={{ color: 'white', fontWeight: '600' }}>
    Save Changes
  </Text>
</TouchableOpacity>
```

