## Database Schema (Future)

```sql
-- [Entities]
CREATE TABLE [entities] (
  id UUID PRIMARY KEY,
  name VARCHAR(255) NOT NULL,
  slug VARCHAR(100) UNIQUE NOT NULL,
  status VARCHAR(20) DEFAULT 'active',
  [type] VARCHAR(20) DEFAULT 'free',
  created_at TIMESTAMP DEFAULT NOW()
);

-- [Main Table]
CREATE TABLE [main_table] (
  id UUID PRIMARY KEY,
  [entity]_id UUID REFERENCES [entities](id),
  [field1] VARCHAR(100),
  [field2] VARCHAR(20),
  model_id VARCHAR(100),
  model_provider VARCHAR(50),
  timestamp TIMESTAMP DEFAULT NOW(),
  status VARCHAR(20),
  [metric1] INTEGER,
  [metric2] INTEGER,
  total INTEGER,
  amount DECIMAL(10, 6),
  latency_ms INTEGER
);

-- [Budgets/Plans]
CREATE TABLE [plans] (
  id UUID PRIMARY KEY,
  [entity]_id UUID REFERENCES [entities](id),
  amount DECIMAL(12, 2),
  currency VARCHAR(3) DEFAULT 'USD',
  period VARCHAR(20),
  start_date DATE,
  end_date DATE
);

-- Alerts
CREATE TABLE [alerts] (
  id UUID PRIMARY KEY,
  [entity]_id UUID REFERENCES [entities](id),
  type VARCHAR(50),
  severity VARCHAR(20),
  title VARCHAR(255),
  message TEXT,
  threshold DECIMAL(10, 2),
  current_value DECIMAL(10, 2),
  acknowledged BOOLEAN DEFAULT FALSE,
  created_at TIMESTAMP DEFAULT NOW()
);
```

