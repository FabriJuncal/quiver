## Usage in React Components

### Basic Example

```tsx
'use client';

import { use[Entity1], use[Entity2] } from '@/hooks';

export function Dashboard() {
  const { data: metrics, loading, error } = use[Entity1]();
  const { data: items } = use[Entity2]();

  if (loading) return <div>Loading...</div>;
  if (error) return <div>Error: {error.message}</div>;

  return (
    <div>
      <h1>Total: {metrics?.total}</h1>
      <ul>
        {items?.map(item => (
          <li key={item.id}>{item.name}</li>
        ))}
      </ul>
    </div>
  );
}
```

### Available Hooks

| Hook | Description |
|------|-------------|
| `use[Entity1]()` | Aggregated metrics |
| `use[Entity2](params?)` | List with filters |
| `use[Entity3]()` | List of entities |
| `use[Entity4](params?)` | Breakdown by category |
| `useAlerts(params?)` | List of alerts |

